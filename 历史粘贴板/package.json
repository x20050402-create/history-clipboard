{
  "name": "clip-history",
  "version": "1.0.0",
  "description": "剪贴历史 - Windows 历史剪贴板工具，自动记录复制的文字、图片和文件",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {},
  "build": {
    "appId": "com.clip-history.app",
    "productName": "剪贴历史",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "剪贴历史"
    }
  }
}
